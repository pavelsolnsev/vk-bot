VK_TOKEN=
VK_GROUP_ID=
# user_id через запятую — ЛС о записи/выходе игроков (+, −, «Играть», «Выйти»)
VK_ADMIN_IDS=
FOOTBALL_API_URL=
FOOTBALL_TOKEN=
# Публичный URL табло (кнопка «Игра началась» в чате). По умолчанию https://tournament.pavelsolntsev.ru
TOURNAMENT_PUBLIC_URL=
FOOTBALL_API_TIMEOUT_MS=5000
# Период фоновой перепроверки доступности сайта после auto-disable (мс).
FOOTBALL_API_RECHECK_MS=30000
# Окно идемпотентности для join/leave (мс): повторы в этом окне уходят с тем же X-Idempotency-Key.
FOOTBALL_API_IDEMPOTENCY_WINDOW_MS=5000
# TTL кэша рейтингов/username из сайта (мс), чтобы реже дергать /api/vk/ratings при частых refresh списка.
FOOTBALL_RATINGS_CACHE_TTL_MS=20000
# Максимальный размер кэша рейтингов/подписей (кол-во vk_user_id в памяти).
FOOTBALL_RATINGS_CACHE_MAX_SIZE=5000
# Интервал поллинга сайта (мс), только пока открыт список в ВК; не меньше 5000.
SITE_ROSTER_POLL_MS=22000
# 1 — временный отладочный лог поллинга (старт/стоп таймера, каждый тик и результат).
SITE_ROSTER_POLL_LOG=
# 1 — печатать каждый HTTP-запрос к сайту (метод, путь, статус или ошибка, время мс). Поллинг roster-snapshot даёт строку каждые ~22 с.
FOOTBALL_API_HTTP_LOG=
# 1 — к строке выше добавлять укороченное тело POST (JSON от бота; токен в теле не передаётся)
FOOTBALL_API_HTTP_LOG_BODY=
DB_HOST=
DB_PORT=3306
DB_USER=
DB_PASSWORD=
DB_NAME=
# Базовая пауза перед перезапуском long-poll после ошибки (мс), дальше растёт 2x: 2000, 4000, 8000...
VK_UPDATES_RESTART_BASE_MS=2000
# Максимальная пауза между перезапусками long-poll после ошибок (мс).
VK_UPDATES_RESTART_MAX_MS=60000
# Интервал heartbeat-лога (мс): показывает, что бот жив + счётчики обработки.
VK_BOT_HEARTBEAT_MS=300000
# После скольких подряд падений long-poll отправлять алерт админам в ЛС.
VK_ALERT_CONSECUTIVE_ERRORS=3
# Минимальная пауза между одинаковыми алертами (мс), чтобы не спамить ЛС.
VK_ALERT_COOLDOWN_MS=600000
